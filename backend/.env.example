# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://office:office@postgres:5432/office_booking?schema=public

# Auth
JWT_SECRET=change-me-please-very-long-random-string
ADMIN_PIN=1234

# Evolution API (WhatsApp)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=
# WhatsApp group JID (e.g. 1203630xxxxxxx@g.us) — used for "espacio liberado" broadcast
EVOLUTION_GROUP_JID=

# Timezone for slots / scheduler
TZ=Europe/Madrid
